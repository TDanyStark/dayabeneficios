---
import Header from "@/components/Header.astro";
import { URL_BASE } from "@/config";
import Layout from "@/layouts/Layout.astro";

const vitamins = [
  { id: "vitamina-a", label: "VITAMINA A",               color: "#d98125", img: "vitamina_a.webp"  },
  { id: "vitamina-c", label: "VITAMINA C",               color: "#f24b0c", img: "vitamina_c.webp"  },
  { id: "vitamina-d", label: "VITAMINA D",               color: "#e00735", img: "vitamina_d.webp"  },
  { id: "zinc",       label: "ZINC",                     color: "#b00061", img: "zinc.webp"         },
  { id: "complejo-b", label: "VITAMINAS DEL COMPLEJO B", color: "#5d0968", img: "complejo_b.webp"  },
  { id: "calcio",     label: "CALCIO",                   color: "#29358f", img: "calcio.webp"       },
  { id: "hierro",     label: "HIERRO",                   color: "#1686cd", img: "hierro.webp"       },
  { id: "magnesio",   label: "MAGNESIO",                 color: "#6db86a", img: "magnesio.webp"     },
];

const zones = [
  {
    id: "dz-1", answer: "vitamina-d",
    bullets: [
      "CONTRIBUYE A LA FORMACIÓN DE LOS DIENTES Y LOS HUESOS.",
      "FAVORECE EL BUEN FUNCIONAMIENTO DEL SISTEMA INMUNE.",
    ],
  },
  {
    id: "dz-2", answer: "vitamina-a",
    bullets: [
      "ESENCIAL PARA LA VISIÓN.",
      "MANTIENE SANOS LOS TEJIDOS Y LA PIEL.",
      "DESEMPEÑA UN PAPEL IMPORTANTE EN EL CRECIMIENTO ÓSEO.",
    ],
  },
  {
    id: "dz-3", answer: "zinc",
    bullets: ["FAVORECE EL BUEN FUNCIONAMIENTO DEL SISTEMA INMUNE."],
  },
  {
    id: "dz-4", answer: "vitamina-c",
    bullets: ["AYUDA A PRODUCIR COLÁGENO, UN TEJIDO QUE CONTRIBUYE A LA CICATRIZACIÓN DE HERIDAS."],
  },
  {
    id: "dz-5", answer: "calcio",
    bullets: [
      "FORTALECE Y PROTEGE LOS HUESOS Y LOS DIENTES.",
      "AYUDA A MANTENER UNA BUENA FUNCIÓN MUSCULAR.",
    ],
  },
  {
    id: "dz-6", answer: "magnesio",
    bullets: ["NECESARIO PARA LA PRODUCCIÓN DE ENERGÍA."],
  },
  {
    id: "dz-7", answer: "hierro",
    bullets: [
      "FUNDAMENTAL PARA FABRICAR LA HEMOGLOBINA (TRANSPORTE DE OXÍGENO DESDE LOS PULMONES AL RESTO DEL CUERPO) Y LA MIOGLOBINA (SUMINISTRO DE OXÍGENO A LOS MÚSCULOS).",
    ],
  },
  {
    id: "dz-8", answer: "complejo-b",
    bullets: [
      "AYUDAN A CONVERTIR LOS ALIMENTOS EN ENERGÍA.",
      "ESENCIALES PARA LA SALUD DE LA PIEL, EL CABELLO, LA SANGRE, LOS MÚSCULOS Y EL CEREBRO.",
    ],
  },
];
---

<Layout>
  <div class="min-h-screen bg-home-bottom-radial pb-10">
    <Header abbott="black" />

    <main class="max-w-7xl mx-auto px-4 md:px-6">

      <!-- Title pill + instruction row -->
      <div class="mb-4">
        <div class="inline-flex items-center gap-3 rounded-full py-2 px-6 mb-3"
             style="background:linear-gradient(135deg,#b10165 0%,#ff2b01 50%,#db8d14 100%);">
          <img src={`${URL_BASE}/images/dayapoint.webp`} class="w-8 h-auto shrink-0" alt="" draggable="false" />
          <h1 class="text-2xl md:text-3xl font-bold text-white">DAYABENEFICIOS</h1>
        </div>
        <div class="flex items-center justify-between gap-4">
          <p id="instruction-text" class="text-sm md:text-base text-black max-w-2xl">
            Para descubrir qué le aporta cada componente de Dayamineral al cuerpo, arrastre cada
            <strong>vitamina y mineral hasta la casilla de los beneficios correspondientes.</strong>
          </p>
          <div id="live-counter" class="flex gap-2 shrink-0">
            <!-- Dayapoints card -->
            <div
              class="rounded-2xl shadow-lg px-3 py-2 text-center min-w-20 flex flex-col items-center gap-1"
              style="background:linear-gradient(135deg,#b10165 0%,#ff2b01 50%,#db8d14 100%);"
            >
              <img src={`${URL_BASE}/images/dayapoint.webp`} class="w-6 h-auto" alt="" draggable="false" />
              <p id="counter-dayapoints" class="text-2xl font-black leading-none text-white">0</p>
              <p class="text-[10px] font-black uppercase tracking-wide text-white/80 leading-tight">Dayapoints</p>
            </div>
            <!-- Intentos card -->
            <div class="rounded-2xl bg-white/85 backdrop-blur-sm border border-white/60 shadow-lg px-3 py-2 text-center min-w-20 flex flex-col items-center gap-1">
              <div class="rounded-full p-1.5 shrink-0" style="background:linear-gradient(135deg,#29358f 0%,#1686cd 100%);">
                <img src={`${URL_BASE}/iconos/rayo.webp`} class="w-4 h-auto" alt="" draggable="false" />
              </div>
              <p id="counter-attempts" class="text-2xl font-black leading-none" style="color:#1686cd;">0</p>
              <p class="text-[10px] font-black uppercase tracking-wide text-gray-500 leading-tight">Intentos</p>
            </div>
          </div>
        </div>
      </div>

      <!-- ── GAME AREA ───────────────────────────────────────────── -->
      <div id="game-area" class="flex flex-col md:flex-row gap-3 md:gap-5 items-start">

        <!-- Vitamins panel -->
        <div
          id="vitamins-panel"
          class="grid grid-cols-2 gap-2 md:flex md:flex-col md:gap-2 w-full md:w-56 shrink-0
                 rounded-xl p-1.5 border-2 border-dashed border-gray-300/60 transition-colors duration-150"
        >
          {vitamins.map((v) => (
            <div
              class="vitamin-pill flex items-center gap-2 rounded-full px-3 py-2 cursor-grab
                     active:cursor-grabbing select-none transition-all duration-150 w-full"
              data-id={v.id}
              data-color={v.color}
              draggable="true"
              style={`background-color:${v.color};`}
            >
              <img
                src={`${URL_BASE}/images/${v.img}`}
                class="w-7 h-7 rounded-full object-contain shrink-0 bg-white/25 p-0.5"
                alt={v.label}
                draggable="false"
              />
              <span class="font-bold text-white text-xs leading-tight">{v.label}</span>
            </div>
          ))}
        </div>

        <!-- Drop zones 2×4 -->
        <div class="grid grid-cols-2 gap-2 md:gap-3 flex-1 w-full">
          {zones.map((z) => (
            <div
              class="drop-zone relative border-2 border-gray-200 rounded-2xl p-2 md:p-3
                     bg-white/65 backdrop-blur-sm flex flex-col"
              data-id={z.id}
              data-answer={z.answer}
            >
              <div class="zone-slot mb-1.5"></div>
              <ul class="space-y-1 flex-1">
                {z.bullets.map((b) => (
                  <li class="text-[9px] md:text-[11px] text-gray-700 flex gap-1 items-start leading-tight">
                    <span class="text-gray-400 shrink-0 mt-px">•</span>
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>

      <!-- ── FINISH CARD ─────────────────────────────────────────── -->
      <div
        id="finish-card"
        class="hidden mt-6 rounded-4xl p-6 md:p-10 text-center text-white shadow-2xl max-w-xl mx-auto"
        style="background:linear-gradient(135deg,#b10165 0%,#ff2b01 50%,#db8d14 100%);"
        aria-live="polite"
      >
        <img
          src={`${URL_BASE}/iconos/check.webp`}
          alt=""
          class="mx-auto mb-4 h-14 w-14"
          aria-hidden="true"
        />
        <h2 class="text-3xl md:text-5xl font-black leading-tight">¡Daya-reto completado!</h2>
        <p class="mx-auto mt-3 max-w-md text-base md:text-lg opacity-90">
          ¡Lograste emparejar todas las vitaminas y minerales con sus beneficios!
        </p>
        <button
          id="retry-btn"
          type="button"
          class="mt-6 rounded-full bg-white px-8 py-3 text-base font-black uppercase
                 text-[#b10165] shadow-lg transition hover:-translate-y-0.5 hover:shadow-xl
                 flex items-center gap-2 mx-auto cursor-pointer"
        >
          <img src={`${URL_BASE}/images/try_again.webp`} class="w-5 h-5" alt="" draggable="false" />
          JUGAR DE NUEVO
        </button>
      </div>

      <!-- References -->
      <p class="mt-8 text-[9px] md:text-[10px] text-gray-400 max-w-2xl leading-relaxed">
        <strong>Referencias:</strong> Harvard Health Publishing. Making sense of vitamins and minerals:
        choosing the foods and nutrients you need to stay healthy [Internet]. Boston (MA): Harvard Medical School; 2020 |
        National Institutes of Health (NIH). Suplementos dietéticos [Internet]. Bethesda (MD): NIH; 2009 |
        Mason JB. Instant benefits, side effects and image [Internet]. Healthline; 2021.
      </p>
    </main>
  </div>

  <!-- ── MODAL ──────────────────────────────────────────────────── -->
  <div
    id="quiz-modal"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/55 p-4 backdrop-blur-sm"
    role="dialog"
    aria-modal="true"
    aria-labelledby="modal-title"
  >
    <article
      id="modal-card"
      class="max-h-[90vh] w-full max-w-md overflow-y-auto rounded-4xl p-6 md:p-8
             flex flex-col items-center text-center shadow-2xl"
    >
      <img
        id="modal-dayapoint"
        src={`${URL_BASE}/images/dayapoint.webp`}
        alt="Dayapoint"
        class="mx-auto mb-3 h-auto w-16"
        draggable="false"
      />
      <img
        id="modal-rayo"
        src={`${URL_BASE}/iconos/rayo.webp`}
        alt=""
        class="mx-auto mb-3 h-auto w-16 hidden"
        draggable="false"
      />
      <h2
        id="modal-title"
        class="text-2xl md:text-3xl font-black leading-tight text-white"
      >
        ¡Anótate un Dayapoint!
      </h2>
      <button
        id="modal-close"
        type="button"
        class="mt-6 rounded-full px-8 py-3 text-sm font-black uppercase shadow-lg
               transition hover:-translate-y-0.5 hover:shadow-xl cursor-pointer
               focus-visible:outline-4 focus-visible:outline-offset-2 focus-visible:outline-white"
        style="background:rgba(255,255,255,0.25); color:#fff; border:2px solid rgba(255,255,255,0.5);"
      >
        CONTINUAR
      </button>
    </article>
  </div>
</Layout>

<style>
  .drop-zone {
    transition: border-color 0.2s, background-color 0.25s, box-shadow 0.25s, transform 0.15s;
  }
  .drop-zone.dz-hover {
    background-color: rgba(255, 255, 255, 0.92) !important;
    transform: scale(1.03);
  }
  #vitamins-panel.panel-hover {
    border-color: #1686cd;
    background-color: rgba(22, 134, 205, 0.06);
  }
  .vitamin-pill.vp-selected {
    box-shadow: 0 0 0 3px #fff, 0 0 0 5px rgba(22, 134, 205, 0.7);
    transform: scale(1.06);
  }
  .vitamin-pill.vp-dragging {
    opacity: 0.25;
  }
  .zone-slot .vitamin-pill {
    cursor: pointer;
  }
  #quiz-modal {
    animation: none;
  }
  #quiz-modal:not(.hidden) {
    display: flex !important;
  }
</style>

<script>
  import confetti from "canvas-confetti";
  window.quizConfetti = confetti;
</script>

<script is:inline define:vars={{ URL_BASE }}>
  // ── STATE ────────────────────────────────────────────────────
  var selectedPillId = null;
  var draggedPillId  = null;
  var pending        = null; // { dzId, itemId, isCorrect }
  var correctCount   = 0;
  var attemptCount   = 0;
  var confettiTimer  = null;
  var TOTAL          = 8;

  var GRAD_CORRECT   = "linear-gradient(135deg,#b10165 0%,#ff2b01 50%,#db8d14 100%)";
  var GRAD_INCORRECT = "linear-gradient(135deg,#29358f 0%,#1686cd 100%)";

  // ── COUNTER ───────────────────────────────────────────────────
  function updateCounter() {
    var el = document.getElementById("counter-dayapoints");
    var ea = document.getElementById("counter-attempts");
    if (el) el.textContent = String(correctCount);
    if (ea) ea.textContent = String(attemptCount);
  }

  // ── CONFETTI ──────────────────────────────────────────────────
  function launchSideConfetti() {
    var confetti = window.quizConfetti;
    if (!confetti) return;
    confetti({
      particleCount: 70,
      spread: 55,
      angle: 60,
      origin: { x: 0, y: 0.55 },
      colors: ["#b10165", "#f4bd18", "#ffffff"],
    });
    confetti({
      particleCount: 70,
      spread: 55,
      angle: 120,
      origin: { x: 1, y: 0.55 },
      colors: ["#b10165", "#f4bd18", "#ffffff"],
    });
  }

  function launchPerfectFinishConfetti() {
    var confetti = window.quizConfetti;
    if (!confetti) return;
    var end = Date.now() + 3000;
    clearInterval(confettiTimer);
    confettiTimer = setInterval(function () {
      confetti({
        particleCount: 55,
        spread: 360,
        startVelocity: 32,
        origin: { x: Math.random(), y: Math.random() * 0.55 },
        colors: ["#b10165", "#f4bd18", "#ffffff", "#1686cd"],
      });
      if (Date.now() > end) clearInterval(confettiTimer);
    }, 250);
  }

  // ── BOOT ─────────────────────────────────────────────────────
  document.addEventListener("DOMContentLoaded", function () {
    adaptInstruction();
    initDragAndDrop();
    initTapToSelect();
    initModal();
    document.getElementById("retry-btn").addEventListener("click", reset);
  });

  // ── INSTRUCTION ──────────────────────────────────────────────
  function adaptInstruction() {
    if ("ontouchstart" in window || navigator.maxTouchPoints > 0) {
      var el = document.getElementById("instruction-text");
      if (el) {
        el.innerHTML =
          "Para descubrir qué le aporta cada componente de Dayamineral al cuerpo, " +
          "<strong>toca una vitamina o mineral para seleccionarlo y luego toca la casilla de los beneficios correspondientes.</strong>";
      }
    }
  }

  // ── DRAG & DROP ───────────────────────────────────────────────
  function initDragAndDrop() {
    document.addEventListener("dragstart", function (e) {
      var pill = e.target.closest(".vitamin-pill");
      if (!pill) return;
      draggedPillId = pill.dataset.id;
      e.dataTransfer.setData("text/plain", pill.dataset.id);
      e.dataTransfer.effectAllowed = "move";
      setTimeout(function () { pill.classList.add("vp-dragging"); }, 0);
    });

    document.addEventListener("dragend", function (e) {
      var pill = e.target.closest(".vitamin-pill");
      if (pill) pill.classList.remove("vp-dragging");
      draggedPillId = null;
      document.querySelectorAll(".dz-hover").forEach(function (z) { z.classList.remove("dz-hover"); });
      var panel = document.getElementById("vitamins-panel");
      if (panel) panel.classList.remove("panel-hover");
    });

    document.querySelectorAll(".drop-zone").forEach(function (zone) {
      zone.addEventListener("dragover", function (e) {
        e.preventDefault();
        zone.classList.add("dz-hover");
      });
      zone.addEventListener("dragleave", function (e) {
        if (!zone.contains(e.relatedTarget)) zone.classList.remove("dz-hover");
      });
      zone.addEventListener("drop", function (e) {
        e.preventDefault();
        zone.classList.remove("dz-hover");
        if (draggedPillId) placeItem(zone.dataset.id, draggedPillId);
      });
    });

    var panel = document.getElementById("vitamins-panel");
    panel.addEventListener("dragover", function (e) {
      e.preventDefault();
      panel.classList.add("panel-hover");
    });
    panel.addEventListener("dragleave", function (e) {
      if (!panel.contains(e.relatedTarget)) panel.classList.remove("panel-hover");
    });
    panel.addEventListener("drop", function (e) {
      e.preventDefault();
      panel.classList.remove("panel-hover");
      if (draggedPillId) {
        var pill = document.querySelector(".vitamin-pill[data-id='" + draggedPillId + "']");
        if (pill) sendToPanel(pill);
      }
    });
  }

  // ── TAP TO SELECT ─────────────────────────────────────────────
  function initTapToSelect() {
    document.addEventListener("click", function (e) {
      var modal = document.getElementById("quiz-modal");
      if (!modal.classList.contains("hidden")) return;

      var pill = e.target.closest(".vitamin-pill");
      if (pill) {
        e.stopPropagation();
        var id = pill.dataset.id;
        if (selectedPillId === id) { deselect(); }
        else { selectPill(id); }
        return;
      }

      var zone = e.target.closest(".drop-zone");
      if (zone && selectedPillId) {
        placeItem(zone.dataset.id, selectedPillId);
        deselect();
      } else if (!zone && !pill) {
        deselect();
      }
    }, true);
  }

  function selectPill(id) {
    deselect();
    selectedPillId = id;
    var el = document.querySelector(".vitamin-pill[data-id='" + id + "']");
    if (el) el.classList.add("vp-selected");
  }

  function deselect() {
    if (selectedPillId) {
      var el = document.querySelector(".vitamin-pill[data-id='" + selectedPillId + "']");
      if (el) el.classList.remove("vp-selected");
    }
    selectedPillId = null;
  }

  // ── CORE: place pill into zone ────────────────────────────────
  function placeItem(dzId, itemId) {
    var modal = document.getElementById("quiz-modal");
    if (!modal.classList.contains("hidden")) return; // modal open, ignore

    var pill = document.querySelector(".vitamin-pill[data-id='" + itemId + "']");
    if (!pill) return;
    var zone = document.querySelector(".drop-zone[data-id='" + dzId + "']");
    if (!zone) return;
    var slot = zone.querySelector(".zone-slot");

    // Displace existing occupant
    var occupant = slot.querySelector(".vitamin-pill");
    if (occupant && occupant !== pill) sendToPanel(occupant);

    // Move pill into zone slot
    slot.appendChild(pill);

    // Colour the zone with the vitamin's brand colour
    var color = pill.dataset.color || "#1686cd";
    applyZoneColor(zone, color);

    // Determine correctness and store pending
    var isCorrect = zone.dataset.answer === itemId;
    pending = { dzId: dzId, itemId: itemId, isCorrect: isCorrect };
    attemptCount++;
    updateCounter();

    openModal(isCorrect);
  }

  function sendToPanel(pill) {
    document.getElementById("vitamins-panel").appendChild(pill);
  }

  // ── ZONE COLORING ─────────────────────────────────────────────
  function applyZoneColor(zone, color) {
    zone.style.borderColor     = color;
    zone.style.borderWidth     = "3px";
    zone.style.borderStyle     = "solid";
    zone.style.backgroundColor = color + "22"; // ~13 % tint
    zone.style.boxShadow       = "0 4px 16px " + color + "50";
  }

  function resetZoneColor(zone) {
    zone.style.borderColor     = "";
    zone.style.borderWidth     = "";
    zone.style.borderStyle     = "";
    zone.style.backgroundColor = "";
    zone.style.boxShadow       = "";
  }

  // ── MODAL ─────────────────────────────────────────────────────
  function initModal() {
    document.getElementById("modal-close").addEventListener("click", closeModal);
    document.getElementById("quiz-modal").addEventListener("click", function (e) {
      if (e.target === e.currentTarget) closeModal();
    });
  }

  function openModal(isCorrect) {
    var card      = document.getElementById("modal-card");
    var dayapoint = document.getElementById("modal-dayapoint");
    var rayo      = document.getElementById("modal-rayo");
    var title     = document.getElementById("modal-title");
    var closeBtn  = document.getElementById("modal-close");

    if (isCorrect) {
      card.style.background = GRAD_CORRECT;
      dayapoint.style.display = "block";
      rayo.classList.add("hidden");
      title.textContent     = "¡Anótate un Dayapoint!";
      closeBtn.textContent  = "CONTINUAR";
      launchSideConfetti();
    } else {
      card.style.background = GRAD_INCORRECT;
      dayapoint.style.display = "none";
      rayo.classList.remove("hidden");
      title.textContent     = "¡Intenta de nuevo!";
      closeBtn.textContent  = "INTENTAR DE NUEVO";
    }

    var modal = document.getElementById("quiz-modal");
    modal.classList.remove("hidden");
    modal.classList.add("flex");
    closeBtn.focus();
  }

  function closeModal() {
    var modal = document.getElementById("quiz-modal");
    modal.classList.add("hidden");
    modal.classList.remove("flex");

    if (!pending) return;

    if (pending.isCorrect) {
      correctCount++;
      updateCounter();
      if (correctCount === TOTAL) {
        setTimeout(showFinish, 250);
      }
    } else {
      // Return vitamin to panel and reset the zone's colour
      var pill = document.querySelector(".vitamin-pill[data-id='" + pending.itemId + "']");
      var zone = document.querySelector(".drop-zone[data-id='" + pending.dzId + "']");
      if (pill) sendToPanel(pill);
      if (zone) resetZoneColor(zone);
    }

    pending = null;
  }

  // ── FINISH ────────────────────────────────────────────────────
  function showFinish() {
    document.getElementById("game-area").classList.add("hidden");
    document.getElementById("finish-card").classList.remove("hidden");
    launchPerfectFinishConfetti();
  }

  function reset() {
    clearInterval(confettiTimer);
    var panel = document.getElementById("vitamins-panel");
    document.querySelectorAll(".drop-zone .zone-slot .vitamin-pill").forEach(function (pill) {
      panel.appendChild(pill);
    });
    document.querySelectorAll(".drop-zone").forEach(function (z) { resetZoneColor(z); });
    correctCount = 0;
    attemptCount = 0;
    pending      = null;
    deselect();
    updateCounter();
    document.getElementById("game-area").classList.remove("hidden");
    document.getElementById("finish-card").classList.add("hidden");
  }
</script>
